rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Nur eingeloggte Nutzer (Admin-Account oder eingeladene Mitglieder) dürfen lesen/schreiben.
    // Es gibt bewusst keine Rollen-Unterscheidung - jeder eingeloggte Nutzer hat vollen Zugriff.
    match /kegelbuch/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
